# MockMate Backend Production Environment Variables

# Server Port (Render provides this automatically)
PORT=8080

# Database Configuration (From Railway MySQL)
SPRING_DATASOURCE_URL=jdbc:mysql://YOUR_RAILWAY_HOST:PORT/railway
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=your_password
SPRING_DATASOURCE_DRIVER=com.mysql.cj.jdbc.Driver
SPRING_JPA_DIALECT=org.hibernate.dialect.MySQLDialect

# CORS Configuration (Your Vercel URL)
# Example: https://mockmate.vercel.app
ALLOWED_ORIGINS=https://mockmate.vercel.app

# AI Provider Configuration
ACTIVE_AI_PROVIDER=GEMINI
GEMINI_API_KEY=your_gemini_key

# Firebase Configuration
# If using service-account.json, provide the path or use the mocked filter
FIREBASE_CONFIG_PATH=classpath:firebase-service-account.json
